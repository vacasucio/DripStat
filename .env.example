# DoseSafe Server — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
APP_BASE_URL=http://localhost:3000

# Open FHIR sandbox (used when no SMART session is active)
FHIR_BASE_URL=https://fhir-open.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d

# Session (generate a long random string for production)
SESSION_SECRET=change-me-to-a-long-random-secret

# SMART on FHIR / Cerner OAuth2
# Register your app at https://code.cerner.com to get these values
CERNER_CLIENT_ID=your-cerner-client-id
CERNER_CLIENT_SECRET=your-cerner-client-secret
CERNER_REDIRECT_URI=http://localhost:3000/callback
