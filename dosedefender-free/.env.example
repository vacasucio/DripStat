# DoseDefender Free — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# Allowed CORS origin in production (comma-separated, no trailing slash)
# Defaults to https://dosedefender.com and http://localhost:3001 if not set
# CORS_ORIGINS=https://dosedefender.com,https://www.dosedefender.com

# JWT signing secret (generate a long random string for production)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin account — set to your email, then register that account via /register
ADMIN_EMAIL=your-email@example.com

# Anthropic API key — required for Snap & Calculate and Medication Import extraction
ANTHROPIC_API_KEY=your-anthropic-api-key
