# DoseDefender Free — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# JWT signing secret (generate a long random string for production)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin account — set to your email, then register that account via /register
ADMIN_EMAIL=sclifford.pharm@gmail.com

# Anthropic API key — required only for Snap & Calculate (OCR image feature)
ANTHROPIC_API_KEY=your-anthropic-api-key
