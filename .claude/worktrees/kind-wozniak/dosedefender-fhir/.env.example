# DoseDefender Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# ── Session & JWT ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-another-long-random-secret

# ── HTTP Basic Auth (optional, legacy — leave unset for local dev) ─────────
# BASIC_AUTH_USER=your-username
# BASIC_AUTH_PASS=your-password

# ── FHIR / Cerner (legacy SMART on FHIR — not used in v2 app) ────────────
FHIR_BASE_URL=https://fhir-open.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d
# CERNER_CLIENT_ID=your-cerner-client-id
# CERNER_CLIENT_SECRET=your-cerner-client-secret
# CERNER_REDIRECT_URI=http://localhost:3000/callback

# ── Stripe Payments ────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Create products/prices at https://dashboard.stripe.com/products
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_annual_price_id_here

# ── Anthropic AI (for Snap & Calculate PRO feature) ───────────────────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Admin ──────────────────────────────────────────────────────────────────
# Email of the designated admin user. Register this account first, then set here.
# Removing this var revokes admin on next server restart.
# ADMIN_EMAIL=sclifford.pharm@gmail.com
